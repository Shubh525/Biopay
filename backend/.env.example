# BioPay Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit your actual .env file.

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required — app will refuse to start without it)
#
# Local development (EC2 PostgreSQL):
#   POSTGRES_URL=postgresql://postgres:password@localhost:5432/palm_vein_auth
#
# Production (AWS RDS — use endpoint from RDS console):
#   POSTGRES_URL=postgresql://biopay_admin:password@<instance>.rds.amazonaws.com:5432/palm_vein_auth
#
POSTGRES_URL=postgresql://biopay_admin:<PASSWORD>@<rds-endpoint>.rds.amazonaws.com:5432/palm_vein_auth

# ── Hardware Bridge ───────────────────────────────────────────────────────────
# Absolute path to the PalmSecure Java SDK bridge JAR
# Required when SIMULATE=false
JAVA_BRIDGE_JAR=/opt/biopay/palmsecure-bridge.jar

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Required — app will refuse to start without it.
JWT_SECRET_KEY=

# AES-256 key used to encrypt biometric templates at rest.
# Required — app will refuse to start without it.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
PALM_AUTH_AES_KEY=

# Flask session signing secret.
# Generate the same way as JWT_SECRET_KEY.
SESSION_SECRET=

# ── App Behaviour ─────────────────────────────────────────────────────────────
# Set to "true" to run without physical palm scanner hardware (uses fake templates)
SIMULATE=false

# Set to "true" ONLY on local development to auto-seed a mock user at startup.
# NEVER set this to "true" on the production server — it will insert test data
# into your clean production database.
SEED_MOCK_DATA=false


# Port the Flask server listens on (Gunicorn overrides this in production)
PORT=5000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# URL of the deployed frontend — used in CORS allow-list and WebSocket origins
# Local dev:   http://localhost:5173
# Production:  https://connectbiopay.com
FRONTEND_URL=https://connectbiopay.com

# ── Email / OTP ───────────────────────────────────────────────────────────────
# Gmail account used to send OTP codes (leave blank to skip real email sending)
SMTP_EMAIL=
SMTP_PASSWORD=
