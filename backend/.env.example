# BioPay Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit your actual .env file.

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required — app will refuse to start without it)
POSTGRES_URL=postgresql://user:password@localhost:5432/biopay

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Required — app will refuse to start without it.
JWT_SECRET_KEY=

# AES-256 key used to encrypt biometric templates at rest.
# Required — app will refuse to start without it.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
PALM_AUTH_AES_KEY=

# Flask session signing secret.
# Generate the same way as JWT_SECRET_KEY.
SESSION_SECRET=

# ── App Behaviour ─────────────────────────────────────────────────────────────
# Set to "true" to run without physical palm scanner hardware (uses fake templates)
SIMULATE=false

# Port the Flask server listens on
PORT=5000

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# URL of the frontend — used in HTTP and WebSocket CORS allow-list
FRONTEND_URL=http://localhost:5173

# ── Email / OTP ───────────────────────────────────────────────────────────────
# Gmail account used to send OTP codes (leave blank to skip real email sending)
SMTP_EMAIL=
SMTP_PASSWORD=
